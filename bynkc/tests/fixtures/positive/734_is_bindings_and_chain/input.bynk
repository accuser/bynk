commons demo

-- #734 regression: a long left-nested `&&` chain of `is Ok(_)` narrowings as
-- an `if` condition. Type-checking the condition recurses through `check_binop`
-- at every `&&` node, each gathering the `is`-bindings of its lhs; without the
-- per-span memoisation (Ctx::is_binding_cache) that walk is O(N^2) in the chain
-- length. Every payload binding (`a`..`e`) is used in the then-branch, so a
-- poisoned/empty cache would drop them and fail to compile with unbound-name
-- errors here.
fn sumIfAllOk(
  r1: Result[Int, String],
  r2: Result[Int, String],
  r3: Result[Int, String],
  r4: Result[Int, String],
  r5: Result[Int, String]
) -> Int {
  if r1 is Ok(a) && r2 is Ok(b) && r3 is Ok(c) && r4 is Ok(d) && r5 is Ok(e) {
    a + b + c + d + e
  } else {
    0
  }
}
