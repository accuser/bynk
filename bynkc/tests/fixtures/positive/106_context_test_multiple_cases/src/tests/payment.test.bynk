suite commerce.payment {
  provides Logger.log(_) returns ()

  case "case one" {
    let r <- authorise.call(10)
    expect r is Ok(_)
  }

  case "case two" {
    let r <- authorise.call(20)
    expect r is Ok(_)
  }

  case "case three" {
    let r <- authorise.call(0)
    expect r is Err(_)
  }
}
