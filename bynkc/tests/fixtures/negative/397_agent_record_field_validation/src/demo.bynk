context demo

-- #711: an agent handler body is checker-only too (the resolver skips agent
-- items, same as service), so record field-set validation must reach it.
-- Substantiates the `agent` half of the fix — same code path as the service
-- fixture, pinned independently.
type Reply = { code: Int, body: String }

agent Box {
  key id: Int

  store seen: Cell[Bool]

  on call ping() -> Effect[Reply] {
    -- missing required `body`, undeclared extra `extra`
    Reply { code: 200, extra: true }
  }
}
