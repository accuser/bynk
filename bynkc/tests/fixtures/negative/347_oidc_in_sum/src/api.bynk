context api

type UserId = String where NonEmpty

type Note = {
  id: String,
  owner: String,
}

actor Member { auth = Oidc(issuer = "https://issuer.example", audience = "my-api", jwks = "https://issuer.example/jwks"), identity = UserId }

service api from http {
  on GET("/notes/:id") (id: String) -> Effect[HttpResult[Note]] by who: Member | Visitor {
    match who {
      Member(u) => Ok(Note { id: id, owner: u })
      Visitor => Ok(Note { id: id, owner: "public" })
    }
  }
}
