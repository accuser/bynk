context s

type RoomId = opaque String
type UserId = opaque String
type ServerFrame = { text: String }

-- A collect-all broadcast borrows each held connection — `send` is allowed, but a
-- consuming op (`close`) on the borrowed `c` inside the closure is rejected.
-- `bynk.held.consume_on_borrow` (the same borrow discipline `parTraverse` obeys).
agent Room {
  key id: RoomId
  store conns: Map[UserId, Connection[ServerFrame]]

  on call closeAll() -> Effect[List[Result[(), String]]] {
    conns.parTraverseAll((c: Connection[ServerFrame]) => {
      do c.close()
      let r: Result[(), String] = Ok(())
      Effect.pure(r)
    })
  }
}
