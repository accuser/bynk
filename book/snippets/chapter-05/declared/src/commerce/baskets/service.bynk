context commerce.baskets

service setBasketLine {
  on call(
    owner: CustomerId,
    sku: Sku,
    quantity: Quantity
  ) -> Effect[()] {
    do Basket(owner).setLine(sku, quantity)
  }
}

service basketSnapshot {
  on call(owner: CustomerId) -> Effect[BasketSnapshot] {
    let basket = Basket(owner)
    let view <- basket.snapshot()
    view
  }
}
