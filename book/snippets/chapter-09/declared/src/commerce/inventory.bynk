context commerce.inventory

type Amount = Int where Positive

agent Stock {
	key sku: String

	store available: Cell[Int] = 0

	invariant nonnegative:
		available >= 0

	on call receive(quantity: Amount) -> Effect[()] { available.update((n) => n + quantity) }

	on call ship(quantity: Amount) -> Effect[()] { available.update((n) => n - quantity) }
}
