{
  "context": {
    "prefix": "context",
    "body": [
      "context ${1:my.orders}",
      "",
      "$0"
    ],
    "description": "A context declaration (effectful boundary: services, agents, providers)."
  },
  "commons": {
    "prefix": "commons",
    "body": [
      "commons ${1:my.lib}",
      "",
      "$0"
    ],
    "description": "A commons declaration (pure, shareable types and functions)."
  },
  "adapter": {
    "prefix": "adapter",
    "body": [
      "adapter ${1:name} {",
      "  binding \"${2:./module}\"",
      "  $0",
      "}"
    ],
    "description": "An adapter declaration (a foreign-module binding)."
  },
  "uses": {
    "prefix": "uses",
    "body": [
      "uses ${1:module}"
    ],
    "description": "Import a sibling module's pure types and functions (`uses <module>`)."
  },
  "consumes": {
    "prefix": "consumes",
    "body": [
      "consumes ${1:bynk} { ${2:Random} }"
    ],
    "description": "Consume a context or platform capability (`consumes <ctx> { … }`)."
  },
  "type record": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = {",
      "  ${2:field}: ${3:Int},",
      "}$0"
    ],
    "description": "A record type."
  },
  "type enum": {
    "prefix": "enum",
    "body": [
      "type ${1:Name} = enum {",
      "  ${2:Variant},$0",
      "}"
    ],
    "description": "A sum (enum) type."
  },
  "type refined": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = ${2:String} where ${3:MinLength(1)}$0"
    ],
    "description": "A refined type (a base type narrowed by a `where` predicate)."
  },
  "type opaque": {
    "prefix": "opaque",
    "body": [
      "type ${1:Name} = opaque ${2:Int} where ${3:NonNegative}$0"
    ],
    "description": "An opaque type (an abstract type over a hidden representation)."
  },
  "fn": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:x}: ${3:Int}) -> ${4:Int} {",
      "  $0",
      "}"
    ],
    "description": "A free function."
  },
  "function with contract": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:x}: ${3:Int}) -> ${4:Int}",
      "  requires ${5:in_range}: ${6:x >= 0}",
      "  ensures ${7:non_negative}: ${8:result >= 0}",
      "{",
      "  $0",
      "}"
    ],
    "description": "A function with a `requires`/`ensures` contract."
  },
  "capability": {
    "prefix": "capability",
    "body": [
      "capability ${1:Name} {",
      "  fn ${2:op}(${3}) -> Effect[${4:()}]",
      "}$0"
    ],
    "description": "A capability (effectful interface)."
  },
  "provides": {
    "prefix": "provides",
    "body": [
      "provides ${1:Cap} = ${2:Impl} {",
      "  fn ${3:op}(${4}) -> Effect[${5:()}] {",
      "    Effect.pure(${6:()})",
      "  }",
      "}$0"
    ],
    "description": "A provider implementing a capability."
  },
  "actor": {
    "prefix": "actor",
    "body": [
      "actor ${1:Name} { auth = ${2:Bearer(secret = \"AUTH_JWT_SECRET\")}, identity = ${3:UserId} }"
    ],
    "description": "An actor (a request-boundary contract consumed via `by`)."
  },
  "service": {
    "prefix": "service",
    "body": [
      "service ${1:name} {",
      "  on call(${2}) -> Effect[${3:()}] {",
      "    Effect.pure(${4:()})",
      "  }",
      "}$0"
    ],
    "description": "A service with a call handler."
  },
  "service call handler": {
    "prefix": "on call",
    "body": [
      "on call(${1}) -> Effect[Result[${2:()}, String]] given ${3:Cap} {",
      "  Ok(${4:()})",
      "}"
    ],
    "description": "A call handler with a capability requirement (`given`)."
  },
  "service http handler": {
    "prefix": "on http",
    "body": [
      "on ${1|GET,POST,PUT,DELETE,PATCH|}(\"${2:/path}\") (${3:body}: ${4:Req}) -> Effect[HttpResult[${5:Res}]] {",
      "  $0",
      "}"
    ],
    "description": "An HTTP service handler."
  },
  "service cron handler": {
    "prefix": "on cron",
    "body": [
      "on schedule(\"${1:0 * * * *}\") () -> Effect[Result[(), String]] {",
      "  $0",
      "  Ok(())",
      "}"
    ],
    "description": "A cron service handler."
  },
  "agent": {
    "prefix": "agent",
    "body": [
      "agent ${1:Name} {",
      "  key ${2:id}: ${3:String}",
      "",
      "  store ${4:count}: Cell[${5:Int}] = ${6:0}",
      "",
      "  invariant ${7:non_negative}: ${8:count >= 0}",
      "",
      "  transition ${9:monotonic}: ${10:new.count >= old.count}",
      "",
      "  on call ${11:peek}(${12}) -> Effect[Result[${13:()}, String]] {",
      "    Ok(${14:()})",
      "  }",
      "}$0"
    ],
    "description": "A durable agent (keyed store fields, invariants, and handlers)."
  },
  "suite": {
    "prefix": "suite",
    "body": [
      "suite ${1:target}",
      "",
      "case \"${2:it works}\" {",
      "  let ${3:actual} = ${4:0}",
      "  expect ${5:actual == 0}",
      "}$0"
    ],
    "description": "A test suite with a case."
  },
  "property": {
    "prefix": "property",
    "body": [
      "property \"${1:invariant holds}\" {",
      "  for all ${2:x}: ${3:Int} {",
      "    expect ${4:x == x}",
      "  }",
      "}$0"
    ],
    "description": "A generative test (`for all …`), inside a suite."
  }
}
