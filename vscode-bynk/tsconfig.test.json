{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out",
    "rootDir": ".",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "mocha"]
  },
  // `src/semanticValues.ts` and `src/inlineDoc.ts` are dependency-free (no
  // `vscode` import), so the unit tests can compile against them directly.
  // `rootDir: "."` keeps `test/` output at `out/test/**` (runTest.js path
  // unchanged) and puts those src files at `out/src/`. Do not broaden this to all
  // of `src` — the rest imports `vscode`.
  "include": [
    "test/**/*.ts",
    "src/semanticValues.ts",
    "src/inlineDoc.ts"
  ]
}
