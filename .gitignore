# Rust build artifacts
target/
**/*.rs.bk

# Insta pending snapshots
**/*.pending-snap
**/snapshots/*.snap.new

# mdBook build output
docs/book/

# `bynkc test` build output written into a fixture dir (never tracked; the
# fixtures are driven from temp dirs, so a committed out/ is stale cruft)
bynkc/tests/fixtures/**/out/
bynkc/tests/fixtures/**/out-js/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
