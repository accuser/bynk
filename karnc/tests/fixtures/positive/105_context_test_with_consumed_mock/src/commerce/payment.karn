context commerce.payment {
  exports opaque { AuthId }
  exports transparent { PaymentError }

  type AuthId = opaque String
  type PaymentError = | Declined

  capability Logger {
    fn log(msg: String) -> Effect[()]
  }

  provides Logger = NoOpLogger {
    fn log(msg: String) -> Effect[()] {
      Effect.pure(())
    }
  }

  service authorise {
    on call(amount: Int) -> Effect[Result[AuthId, PaymentError]] given Logger {
      let _ <- Logger.log("authorise")
      Effect.pure(Ok(AuthId.unsafe("AUTH-DEFAULT")))
    }
  }
}
