context api

type UserId = String where NonEmpty

type View = { ok: Bool }

capability Logger {
	fn log(msg: String) -> Effect[()]
}

actor User { auth = Bearer(secret = "AUTH_JWT_SECRET"), identity = UserId }

service api from http {
	on GET("/ping") () -> Effect[HttpResult[View]] by Visitor { Ok(View { ok: true }) }

	on GET("/me") () -> Effect[HttpResult[View]] by u: User given Logger {
		let _ <- Logger.log("me")
		Ok(View { ok: true })
	}

	on POST("/notes/:id") (id: String) -> Effect[HttpResult[View]] by who: User | Visitor {
		match who {
			User(u) => Ok(View { ok: true }),
			Visitor => Ok(View { ok: false }),
		}
	}
}
