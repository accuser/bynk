---
// Bynk head override: the default Starlight <head> plus the web-font stylesheet.
// Inter (variable) carries body and UI text; Literata (variable, with an italic
// axis) is the display face for the wordmark and headings. We load them with a
// plain Google Fonts <link> — not Astro's `fonts` API — because that API's dev
// pipeline interfered with the content-collection sync in the dev server (empty
// `docs` collection → site-wide 404s), whereas a stylesheet link is inert with
// respect to the build and works the same in dev, build, and sync. brand.css
// binds these families to Starlight's `--sl-font` and the heading rules.
import Default from "@astrojs/starlight/components/Head.astro";
---

<Default />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Literata:ital,opsz,wght@0,7..72,200..900;1,7..72,200..900&display=swap"
/>
