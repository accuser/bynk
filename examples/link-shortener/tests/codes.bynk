test codes

-- The `Slug`/`Url` boundary constraints and the key helper are pure, so they are
-- tested directly — no Random, no KV, no HTTP.

test "keyOf namespaces a slug" {
  assert keyOf(Mock[Slug]("a1b2c3d4")) == "link:a1b2c3d4"
}

test "a slug must be 6–12 characters" {
  assert Slug.of("abc")          is Err(_)   -- too short
  assert Slug.of("a1b2c3")       is Ok(_)    -- 6, the minimum
  assert Slug.of("a1b2c3d4e5f6") is Ok(_)    -- 12, the maximum
  assert Slug.of("a1b2c3d4e5f6g") is Err(_)  -- 13, too long
}

test "a url must be non-empty and bounded" {
  assert Url.of("")                  is Err(_)
  assert Url.of("https://bynk.dev")  is Ok(_)
}
